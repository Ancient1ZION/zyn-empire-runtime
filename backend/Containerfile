# ZYN Empire Backend -- Containerfile (Podman/Docker compatible)
# Build: podman build -t zyn-backend -f backend/Containerfile backend/
FROM docker.io/library/node:20-alpine
LABEL maintainer="ZYN Empire"
LABEL version="6.6"
RUN addgroup -S zyn && adduser -S zyn -G zyn
WORKDIR /app
COPY package*.json ./
RUN npm ci --only=production && npm cache clean --force
COPY . .
RUN chown -R zyn:zyn /app
USER zyn
EXPOSE 3000
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
  CMD wget -qO- http://localhost:3000/ping || exit 1
CMD ["node", "server.js"]
