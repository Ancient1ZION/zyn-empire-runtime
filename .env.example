# ZYN Empire Runtime -- Environment Variables
# Copy to .env and fill in your values

# GCP VM
GCP_VM_IP=35.185.40.28
PORT=3000
NODE_ENV=production

# SAM.gov API
SAM_API_KEY=your_sam_gov_api_key
SAM_API_BASE=https://api.sam.gov/opportunities/v2/search

# AI APIs
GROQ_API_KEY=your_groq_key
CEREBRAS_API_KEY=your_cerebras_key
OPENROUTER_API_KEY=your_openrouter_key
HF_API_KEY=your_hf_key
ELEVENLABS_API_KEY=your_elevenlabs_key

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# MiroFish
MIROFISH_API=http://localhost:5001

# Google Apps Script
GAS_EMAIL_URL=https://script.google.com/macros/s/YOUR_ID/exec
GAS_SAM_URL=https://script.google.com/macros/s/YOUR_SAM_ID/exec

# Discord
DISCORD_WEBHOOK=https://discord.com/api/webhooks/YOUR_WEBHOOK
OPP_WEBHOOK=https://discord.com/api/webhooks/YOUR_OPP_WEBHOOK
ALERT_WEBHOOK=https://discord.com/api/webhooks/YOUR_ALERT_WEBHOOK

# Firecrawl
FIRECRAWL_API_KEY=fc-your_key
FIRECRAWL_URL=http://localhost:3002

# Redis
REDIS_URL=redis://localhost:6379

# ZYN Business
ZYN_WEBSITE=https://zynsupplyandlogistics.com
ZYN_NAICS=541512,541519,541611,541614
ZYN_STATE=FL
